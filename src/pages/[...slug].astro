---
import fs from "fs";
import Page from "../layouts/Page.astro";

import { Editor } from "@/components/Editor";
import { FileTree } from "@/components/FileTree";
import { loadConfig } from "@/lib/config";
import { getFiles } from "@/lib/files";
import { resolvePublicImagePath } from "@/lib/images";
import { getTargetPath, resolveMarkdownFilePath } from "@/lib/paths";
import { imageResponse } from "@/lib/responses";

const { slug } = Astro.params;

let filePath: string;
if (!slug) {
  filePath = "";
} else {
  filePath = slug;
}

const targetPath = getTargetPath();
const config = await loadConfig();
const imagePath = resolvePublicImagePath({
  targetPath,
  uploadDir: config.images.uploadDir,
  publicPath: config.images.publicPath,
  requestPath: filePath,
});
const uploadedImageResponse = imagePath ? imageResponse(imagePath) : null;

if (uploadedImageResponse) {
  return uploadedImageResponse;
}

const files = getFiles(targetPath);

const fullPath = resolveMarkdownFilePath(targetPath, filePath);

let content = "*Select or create a file to edit.*";
let readOnly = true;

if (filePath != "") {
  if (fullPath && fs.existsSync(fullPath)) {
    content = fs.readFileSync(fullPath, "utf-8");
    readOnly = false;
  } else {
    return new Response(null, {
      status: 404,
      statusText: "Not found",
    });
  }
}
---

<Page>
  <Fragment slot="file-tree">
    <FileTree items={files} activePath={`/${slug}`} client:only="react" />
  </Fragment>
  <Fragment slot="editor">
    <Editor
      readOnly={readOnly}
      content={content}
      filePath={filePath || undefined}
      client:only="react"
    />
  </Fragment>
</Page>
