---
import Layout from "../layouts/Layout.astro";

import { Alert } from "@/components/Alert";
import { SavingStatus } from "@/components/SavingStatus";
import { readFlash } from "@/lib/flash";

import "@shoelace-style/shoelace/dist/themes/light.css";
import CollapseSidebarIcon from "pixelarticons/svg/arrow-bar-left.svg?url";
import ExpandSidebarIcon from "pixelarticons/svg/arrow-bar-right.svg?url";

interface Props {
  title?: string;
}

const { title } = Astro.props;

const { error, success, filename } = readFlash(Astro.cookies);
---

<Layout title={title ? `${title} — SSG Editor` : "SSG Editor"}>
  <header
    class="flex justify-between h-12 items-center border-b-2 border-black bg-background"
  >
    <h1 class="truncate px-3 text-xl font-mono font-bold tracking-tight">
      SSG Editor
    </h1>
    <SavingStatus client:only="react" />
  </header>

  <Alert
    error={error}
    success={success}
    filename={filename}
    client:only="react"
  />

  <div class="editor-shell flex">
    <!-- Backdrop closes the overlay sidebar on small screens -->
    <button
      type="button"
      class="sidebar-backdrop"
      id="file-sidebar-backdrop"
      aria-label="Close file sidebar"
      tabindex="-1"
      hidden></button>
    <!-- Side Panel -->
    <div
      class="sidebar-panel flex flex-col border-r-2 border-black"
      id="file-sidebar"
    >
      <div class="sidebar-header">
        <h2 class="sidebar-title text-lg font-mono tracking-tight">Files</h2>
        <button
          type="button"
          class="sidebar-toggle"
          id="file-sidebar-toggle"
          aria-controls="file-sidebar"
          aria-expanded="true"
          aria-label="Collapse file sidebar"
          title="Collapse file sidebar"
        >
          <img
            class="sidebar-toggle-icon sidebar-toggle-icon-collapse"
            src={CollapseSidebarIcon}
            alt=""
            aria-hidden="true"
          />
          <img
            class="sidebar-toggle-icon sidebar-toggle-icon-expand"
            src={ExpandSidebarIcon}
            alt=""
            aria-hidden="true"
          />
        </button>
      </div>
      <div class="sidebar-content flex-grow overflow-y-auto">
        <slot name="file-tree" />
      </div>
    </div>

    <!-- Main Editor Area -->
    <div class="editor-panel flex-grow flex flex-col relative bg-gray-100">
      <div
        class="h-full px-4 py-4 lg:px-8 flex flex-col items-center justify-start overflow-y-auto"
      >
        <div
          class="editor-surface bg-white w-full max-w-4xl h-full shadow-md overflow-hidden"
        >
          <slot name="editor" />
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .tree-with-icons::part(label) {
    font-family:
      ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono",
      "Courier New", monospace;
  }

  .editor-shell {
    height: calc(100vh - 3rem);
    min-height: 0;
    overflow: hidden;
  }

  .sidebar-panel {
    width: 18rem;
    min-width: 18rem;
    height: 100%;
    background: var(--color-background);
    transition:
      width 180ms ease,
      min-width 180ms ease;
  }

  .sidebar-panel.is-collapsed {
    width: 3.5rem;
    min-width: 3.5rem;
  }

  .sidebar-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    min-height: 3.75rem;
    padding: 1rem 0.75rem;
  }

  .sidebar-title {
    margin: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .sidebar-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    flex: 0 0 2rem;
    border: 0;
    background: transparent;
    cursor: pointer;
  }

  .sidebar-toggle:hover {
    background: #f3f4f6;
  }

  .sidebar-toggle:focus-visible {
    outline: 2px solid black;
    outline-offset: 2px;
  }

  .sidebar-toggle-icon {
    width: 1rem;
    height: 1rem;
  }

  .sidebar-toggle-icon-expand {
    display: none;
  }

  .sidebar-content {
    opacity: 1;
    transition: opacity 120ms ease;
  }

  .sidebar-panel.is-collapsed .sidebar-header {
    justify-content: center;
    padding-inline: 0.5rem;
  }

  .sidebar-panel.is-collapsed .sidebar-title,
  .sidebar-panel.is-collapsed .sidebar-content,
  .sidebar-panel.is-collapsed .sidebar-toggle-icon-collapse {
    display: none;
  }

  .sidebar-panel.is-collapsed .sidebar-toggle-icon-expand {
    display: block;
  }

  .editor-panel {
    min-width: 0;
    height: 100%;
  }

  .editor-surface {
    min-height: 24rem;
  }

  .sidebar-backdrop {
    display: none;
    border: 0;
    padding: 0;
    margin: 0;
    cursor: pointer;
  }

  @media (max-width: 640px) {
    .editor-shell {
      position: relative;
    }

    .sidebar-panel:not(.is-collapsed) {
      position: absolute;
      inset: 0 auto 0 0;
      z-index: 1000;
      width: min(18rem, calc(100vw - 3.5rem));
      min-width: min(18rem, calc(100vw - 3.5rem));
      background: white;
      box-shadow: 4px 0 0 rgb(0 0 0 / 0.16);
    }

    .sidebar-panel.is-collapsed {
      position: relative;
    }

    .editor-panel {
      width: 100%;
    }

    /* Backdrop sits under the open overlay sidebar but over the editor. */
    .sidebar-backdrop:not([hidden]) {
      display: block;
      position: absolute;
      inset: 0;
      z-index: 900;
      background: rgb(0 0 0 / 0.32);
    }
  }
</style>

<script>
  const isNarrow = () => window.matchMedia("(max-width: 640px)").matches;

  const setSidebarCollapsed = (isCollapsed: boolean) => {
    const sidebar = document.getElementById("file-sidebar");
    const toggle = document.getElementById("file-sidebar-toggle");
    const backdrop = document.getElementById("file-sidebar-backdrop");

    if (!sidebar || !toggle) {
      return;
    }

    sidebar.classList.toggle("is-collapsed", isCollapsed);
    toggle.setAttribute("aria-expanded", String(!isCollapsed));
    toggle.setAttribute(
      "aria-label",
      isCollapsed ? "Expand file sidebar" : "Collapse file sidebar",
    );
    toggle.setAttribute(
      "title",
      isCollapsed ? "Expand file sidebar" : "Collapse file sidebar",
    );
    if (backdrop) {
      backdrop.hidden = isCollapsed || !isNarrow();
    }
  };

  // Binds listeners to the freshly rendered header/sidebar after every
  // navigation — the ClientRouter swaps that DOM, dropping prior listeners.
  const setupSidebar = () => {
    const sidebar = document.getElementById("file-sidebar");
    const toggle = document.getElementById("file-sidebar-toggle");
    const backdrop = document.getElementById("file-sidebar-backdrop");

    if (!sidebar || !toggle) {
      return;
    }

    // Collapse by default on small screens (e.g. after opening a file).
    setSidebarCollapsed(isNarrow());

    toggle.addEventListener("click", () => {
      setSidebarCollapsed(!sidebar.classList.contains("is-collapsed"));
    });

    backdrop?.addEventListener("click", () => setSidebarCollapsed(true));
  };

  // Document-level listener is bound once; it reads current DOM at fire time.
  document.addEventListener("keydown", (event) => {
    const sidebar = document.getElementById("file-sidebar");
    if (
      event.key === "Escape" &&
      isNarrow() &&
      sidebar &&
      !sidebar.classList.contains("is-collapsed")
    ) {
      setSidebarCollapsed(true);
    }
  });

  document.addEventListener("astro:page-load", setupSidebar);
</script>
