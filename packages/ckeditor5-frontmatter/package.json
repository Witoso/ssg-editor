{
  "name": "@witoso/ckeditor5-frontmatter",
  "version": "2.0.0",
  "description": "A plugin for CKEditor 5 that handles markdown frontmatter.",
  "keywords": [
    "ckeditor",
    "ckeditor5",
    "ckeditor 5",
    "ckeditor5-feature",
    "ckeditor5-plugin",
    "ckeditor5-dll",
    "ckeditor5-package-generator"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./*": "./dist/*",
    "./browser/*": null,
    "./package.json": "./package.json"
  },
  "license": "GPL-2.0-or-later",
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=24.11.0",
    "pnpm": ">=11.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Witoso/ssg-wysiwig.git",
    "directory": "packages/ckeditor5-frontmatter"
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "ckeditor5-metadata.json"
  ],
  "dependencies": {},
  "peerDependencies": {
    "@ckeditor/ckeditor5-core": "^48.0.0",
    "ckeditor5": "^48.0.0"
  },
  "devDependencies": {
    "@ckeditor/ckeditor5-core": "48.2.0",
    "@ckeditor/ckeditor5-dev-build-tools": "56.1.0",
    "@ckeditor/ckeditor5-dev-translations": "56.1.0",
    "@ckeditor/ckeditor5-inspector": "^5.0.1",
    "@types/node": "^25.9.2",
    "@vitest/browser-playwright": "^4.1.8",
    "@vitest/coverage-istanbul": "^4.1.0",
    "ckeditor5": "48.2.0",
    "playwright": "^1.60.0",
    "typescript": "5.5.4",
    "vite": "^8.0.0",
    "vite-plugin-svgo": "^2.0.0",
    "vitest": "^4.1.0"
  },
  "scripts": {
    "start": "vite",
    "build": "pnpm run build:types && pnpm run build:npm && pnpm run build:browser",
    "build:npm": "vite build --mode npm",
    "build:browser": "vite build --mode browser",
    "build:types": "tsc -p tsconfig.build.json",
    "test": "vitest",
    "test:debug": "vitest --inspect-brk --no-file-parallelism --browser.headless=false",
    "translations:synchronize": "node ./scripts/synchronize-translations.js",
    "translations:validate": "node ./scripts/synchronize-translations.js --validate-only",
    "prepublishOnly": "pnpm run build"
  }
}
